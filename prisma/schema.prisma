generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MAIN_ADMIN
  MANAGER
  AGENT
}

enum BlockType {
  WORKING
  REST
  EXTRA_TIME
}

enum SchemaType {
  DAILY
  WEEKLY
  MONTHLY
}

enum EventType { // @dev useful comments for report, below
  SEED // CALLBACK. books a call as a "Callback" -> Since I have now exact way to now this, I will just count each call as a seed, by now.
  LEAD // WATERING. Callback is performed AKA agent calls a callee more than 1 time: Every call from this increases +1 LEAD
  SALE // HARVEST. Agent books a call as a deal -> the call data has order_ids.length more than 1
}

enum UserStatus {
  PAUSED
  ACTIVE
  REMOVED // not return point, but we keep it due to historical reasons
}

enum THIRD_PARTY_SERVICES {
  LEADDESK
}

enum WEEK_DAYS {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String   // Store hashed passwords only
  role          Role     @default(AGENT)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations to your existing entities
  companyId     Int
  company       Company  @relation(fields: [companyId], references: [id])
  
  // Optional links depending on the role
  managerProfile Manager? @relation(fields: [managerId], references: [id])
  managerId      Int?     @unique
  
  agentProfile   Agent?   @relation(fields: [agentId], references: [id])
  agentId        Int?     @unique

  status         UserStatus @default(ACTIVE) // REMOVED is used when "deleted" -> we can not delete it directly due to historical data. 
  // Constraint: One MAIN_ADMIN per company
  // This is enforced via a unique partial index in the DB (see note below)
}

model Company {
  id                Int           @id @default(autoincrement())
  name              String
  createdAt         DateTime      @default(now())
  managers          Manager[]
  agents            Agent[]
  calls             Call[]
  TimeSchemas       Schema[]
  users             User[]
  temporalGoals     TemporalGoals[] // goals list 
  GoalsAssignation  GoalsAssignation[] // assigns 1 TemporalGoal to a specific day (date)
  schemaAssignation  SchemaAssignation[] // assigns 1 TemporalGoal to a specific day (date)
  apiKey            APIKeysAuth?
  // Third party custom data 
  leadDeskCustomData LeadDeskCustomData?
}

// 1-to-1 company-key (used to authenticate webhook call origin)
model APIKeysAuth {
  id            Int      @id @default(autoincrement())
  
  // Use UUIDs for the keys. 
  // 'public' is a reserved keyword in some DBs, 'publicKey' is safer.
  publicKey     String   @unique // uuid prefixed with a specific string exp: "prefix-uuid" 
  secretKeyHash String   @unique // hashed secret 
  // Link to company and ensure 1-to-1
  company       Company  @relation(fields: [companyId], references: [id])
  companyId     Int      @unique 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -------- START CUSTOM DATA SECTION ---------
// For each connection to third party, is required some specific data that variates depending on the service
// for that reason, we create a specific table for each service (if needed) designed to store the specific values 
// all this models are named with the convention [ThirdPartyName]+CustomMetadata
model LeadDeskCustomData {
  id            Int      @id @default(autoincrement())
  authString    String // 32-bytes string provided by LeadDesk to authenticate calls to its API -> used, for example, when fetch call data in webhook handler
  //
  company       Company  @relation(fields: [companyId], references: [id]) 
  companyId     Int      @unique
}
// -------- END CUSTOM DATA SECTION ---------

model Manager {
  id        Int     @id @default(autoincrement())
  name      String
  email     String  @unique
  company   Company @relation(fields: [companyId], references: [id]) // companyId is the foreign key, and it is compared with the `id` field of the other table
  companyId Int
  user      User?
  temporalGoals TemporalGoals[]
  schemas   Schema[]
}

model Agent {
  id                    Int             @id @default(autoincrement())
  name                  String
  company               Company         @relation(fields: [companyId], references: [id])
  companyId             Int
  calls                 Call[]
  feelings              AgentState[]
  events                FunnelEvent[]
  user                  User?
  totalAttempsPerCallee agentToCallee[]
  agentToThird          AgentToThird[] 
  agentLevel            AgentLevel[]
}

model AgentToThird {
  id                     Int                  @id @default(autoincrement())
  serviceIdentifier      THIRD_PARTY_SERVICES 
  agentServiceIdentifier String 

  // Relation fields
  agent                  Agent                @relation(fields: [agentId], references: [id])
  agentId                Int

  @@unique([agentId, serviceIdentifier]) // agent can have only 1 relation for the same service
  @@unique([serviceIdentifier, agentServiceIdentifier]) // only 1 agent service identifier per service
}





model Callee {
  id                     Int            @id @default(autoincrement())
  phoneNumber            String         @unique
  totalAttempts          Int            @default(0)
  calls                  Call[]
  totalAttempsPerAgent   agentToCallee[]  
}

// tracks the number of times an agent calls the same number
// @dev maybe in future, would be better to track "per campaign" too
model agentToCallee {
  id              Int    @id @default(autoincrement())
  agent           Agent  @relation(fields: [agentId], references: [id])
  agentId         Int
  callee          Callee @relation(fields: [calleeId], references: [id])
  calleeId        Int
  totalAttemps    Int    @default(0)

  @@unique([agentId, calleeId])
}

// --- BLOCKS MASKS ---
// Managers create time schedules by block, so the can filter the call querying by such blocks 

model Schema {
  id                Int                @id @default(autoincrement())
  name              String
  company           Company            @relation(fields: [companyId], references: [id])
  companyId         Int
  creator           Manager            @relation(fields: [creatorId], references: [id])
  creatorId         Int
  blocks            SchemaBlock[]
  schemaAssignations SchemaAssignation[]
}

model SchemaBlock {
  id                        Int         @id @default(autoincrement())
  startMinutesFromMidnight  Int
  endMinutesFromMidnight    Int
  blockType                 BlockType   @default(WORKING)
  name                      String?     // (e.g., "Morning Blitz", "Afternoon Follow-ups")
  Schema                    Schema      @relation( fields: [schemaId], references: [id] )
  schemaId                  Int
}

model SchemaAssignation {
  id                Int           @id         @default(autoincrement())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         Int
  schema            Schema   @relation(fields: [schemaId], references: [id])
  schemaId           Int
  date              DateTime // day at which the goals are assigned 

  @@unique([companyId, date])
}

// --- PERFORMANCE DATA ---

model Call {
  id                Int              @id @default(autoincrement())
  agent             Agent            @relation(fields: [agentId], references: [id])
  agentId           Int
  callee            Callee           @relation(fields: [calleeId], references: [id])
  calleeId          Int
  company           Company           @relation(fields: [companyId], references: [id])
  companyId         Int
  startAt           DateTime         @default(now())
  endAt             DateTime?
  durationSeconds   Int              @default(0)
  // isEffective       Boolean          @default(false)
  
  events            FunnelEvent[]

  // 
  dayOfTheWeek      WEEK_DAYS 

}

model FunnelEvent {
  id        Int       @id @default(autoincrement())
  type      EventType
  timestamp DateTime  @default(now())
  call      Call      @relation(fields: [callId], references: [id])
  callId    Int
  agent     Agent     @relation(fields: [agentId], references: [id])
  agentId   Int
}

model AgentState {
  id              Int      @id @default(autoincrement())
  agent           Agent    @relation(fields: [agentId], references: [id])
  agentId         Int
  timestamp       DateTime @default(now())
  energyScore     Int      // 1-10
  focusScore      Int      // 1-10
  motivationScore Int      // 1-10
}

// 1 agent to many agentLevel
// updated weekly automatically could be AWS lambda updates (per batch of users), native pg-cron or AWS functions
/*
Cool, finally, the current agentLevel depends on the next:
- 1 agent has many Call rows. A call has a  durationSeconds column. 
- So, the level depends on: if total call duration of the week was more than X, then is level one, if was less than X but more than Y, is level 2, and if was less than Y, is level 3. 
- So, by calculating this, the stored procedure should: if the state doesnt, changes, dont make anything. If changes, creates the new row, and update the till and durationInWeeks column of the previous latest row. 
*/
model AgentLevel {
  id                Int       @id @default(autoincrement())
  agent             Agent     @relation(fields: [agentId], references: [id])
  agentId           Int
  since             DateTime  @default(now())
  till              DateTime? 
  durationInWeeks   Int       @default(0) // everytime a new row for a user is created, we calculate this ones, then just SUM the values and calculate on-the-fly for the latest row
  level             Int // 1 GOLD. 2 SILVER. 3 BRONZE 

  @@index([agentId, level]) 
}



model TemporalGoals {
  id                Int      @id @default(autoincrement())
  name              String // i.e hard goals, newbies goals...

  // Productivity Targets
  talkTimeMinutes   Int      @default(0)
  seeds             Int      @default(0)
  callbacks         Int      @default(0)
  leads             Int      @default(0)
  sales             Int      @default(0)
  numberOfCalls     Int      @default(0)
  numberOfLongCalls Int      @default(0)
  // Relations
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         Int
  creator           Manager  @relation(fields: [creatorId], references: [id])
  creatorId         Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goalsAssignation  GoalsAssignation[]
}

model GoalsAssignation {
  id                Int           @id         @default(autoincrement())
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         Int
  goal              TemporalGoals @relation(fields: [goalId], references: [id])
  goalId            Int
  date              DateTime // day at which the goals are assigned 

  @@unique([companyId, date])
}
